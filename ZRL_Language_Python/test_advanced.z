# 14. 列表推导式模拟测试
print("14. 列表操作:")
var nums = list([1, 2, 3, 4, 5])
var squared = list()
for n in nums:
    append(squared, n ** 2)
print("  原始:", nums)
print("  平方:", squared)

var filtered = list()
for n in nums:
    if n % 2 == 0:
        append(filtered, n)
print("  偶数:", filtered)
print()

# 15. 字典操作测试
print("15. 字典操作:")
var scores = dict()
set_dict(scores, "张三", 85)
set_dict(scores, "李四", 92)
set_dict(scores, "王五", 78)
print("  成绩字典:", scores)
print("  张三的成绩:", get_dict(scores, "张三"))
print("  是否包含李四:", contains(keys(scores), "李四"))
print()

