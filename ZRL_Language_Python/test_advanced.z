# 17. 复杂条件测试
print("17. 复杂条件:")
var age = 25
var has_license = true
var has_car = false

if age >= 18 and has_license:
    if has_car:
        print("  可以开车")
    else:
        print("  有驾照但没有车")
else:
    print("  不能开车")
print()

# 18. 嵌套循环测试
print("18. 嵌套循环:")
print("  乘法表 (3x3):")
for i in range(1, 4):
    var row = ""
    for j in range(1, 4):
        row = row + str(i * j) + " "
    print("  ", row)
print()

# 19. 函数作为参数测试
print("19. 函数操作:")
func apply_func(fn, x, y):
    return fn(x, y)

func add(a, b):
    return a + b

func multiply(a, b):
    return a * b

print("  add(5, 3) =", add(5, 3))
print("  multiply(4, 3) =", multiply(4, 3))
print()

# 20. 综合测试
print("20. 综合测试:")
func process_data(data):
    var result = list()
    for item in data:
        if item > 0:
            append(result, item * 2)
    return result

var input_data = list([-1, 2, -3, 4, 5])
var output_data = process_data(input_data)
print("  输入:", input_data)
print("  处理后 (正值x2):", output_data)
print()

print("=== 所有高级功能测试完成 ===")